    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- https://vocab.org/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="https://vocab.org/vann/preferredNamespacePrefix"/>
    


    <!-- https://vocab.org/vann/preferredNamespaceURI -->

    <owl:AnnotationProperty rdf:about="https://vocab.org/vann/preferredNamespaceURI"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#positionedBy -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#positionedBy">
        <rdfs:subPropertyOf>
            <rdf:Description>
                <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#positionsObject"/>
            </rdf:Description>
        </rdfs:subPropertyOf>
        <rdfs:domain rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL#Object"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPosition"/>
        <rdfs:label xml:lang="en">positioned by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#positionsObject -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#positionsObject"/>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#atInterval -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/localisation/loca#atInterval">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/localisation/loca#TimedLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2006/time#Interval"/>
        <rdfs:label xml:lang="en">at interval</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#atLocation -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/localisation/loca#atLocation">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/localisation/loca#TimedLocation"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
        <rdfs:label xml:lang="en">at location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#forEntity -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/localisation/loca#forEntity">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/localisation/loca#hasTimedLocation"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/localisation/loca#TimedLocation"/>
        <rdfs:range rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL#Entity"/>
        <rdfs:label xml:lang="en">for entity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#hasTimedLocation -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/localisation/loca#hasTimedLocation">
        <rdfs:label xml:lang="en">has timed location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#location -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/localisation/loca#location">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
        <rdfs:comment xml:lang="en">Generic property assigning some location to a Thing.</rdfs:comment>
        <rdfs:label xml:lang="en">location</rdfs:label>
    </owl:ObjectProperty>
    


