    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL#Entity -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL#Entity"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL#Object -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL#Object"/>
    


    <!-- http://www.ontologydesignpatterns.org/ont/dul/DUL#Situation -->

    <owl:Class rdf:about="http://www.ontologydesignpatterns.org/ont/dul/DUL#Situation"/>
    


    <!-- http://www.w3.org/2006/time#Interval -->

    <owl:Class rdf:about="http://www.w3.org/2006/time#Interval"/>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature"/>
    


    <!-- https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPosition -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPosition">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/list2/list2#OWLList"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/list2/list2#OWLList -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/list2/list2#OWLList"/>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#AreaLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#AreaLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
        <rdfs:label xml:lang="en">Area location</rdfs:label>
        <skos:definition xml:lang="en">The class of all locations that are neither spot, nor linear. Concrete examples: the location of a GSM coverage area (i.e. the parts of topology elements that are in this area); a set of discontinuous or branching linear locations. An area location refers to a set of topology elements, or element parts: no order, no repetition.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#BaseLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#BaseLocation">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL#Object"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature"/>
        <rdfs:label xml:lang="en">Base location</rdfs:label>
        <skos:definition xml:lang="en">Class of all locations relative to a topology. Disjoint union of its three subclasses (spot-, linear-, area location).</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#ConnectedAreaLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#ConnectedAreaLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/localisation/loca#AreaLocation"/>
        <rdfs:comment xml:lang="en">Area location, all elements of which are connected with all other elements, directly or indirectly (ports connected transitively).</rdfs:comment>
        <rdfs:label xml:lang="en">Connected area location</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#LinearLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#LinearLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
        <rdfs:label xml:lang="en">Linear location</rdfs:label>
        <skos:definition xml:lang="en">Location extending over consecutive linear elements or parts thereof. The involved linear elements are in a sequence (ordered list, with repetitions allowed). Each linear element in the sequence is oriented from start to end. Start and end may coincide with extremities or some point in between.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#SpotLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#SpotLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
        <rdfs:label xml:lang="en">Spot location</rdfs:label>
        <skos:definition xml:lang="en">Class of all spot locations, i.e. locations that can be represented as a point on a map or schema. The spot location can relate to one or more net elements (concrete example: the location of a signal that addresses two converging tracks).</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#TimedLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#TimedLocation">
        <rdfs:subClassOf rdf:resource="http://www.ontologydesignpatterns.org/ont/dul/DUL#Situation"/>
        <rdfs:comment xml:lang="en">a situation bringing together an Entity with a location and a time interval. It is a reified ternary relation, not a &quot;Location&quot; as the label would suggest.</rdfs:comment>
        <rdfs:label xml:lang="en">Timed location</rdfs:label>
    </owl:Class>
    


