<?xml version="1.0"?>
<rdf:RDF xmlns="https://cdm.ovh/rsm/localisation/loca#"
     xml:base="https://cdm.ovh/rsm/localisation/loca"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:dul="http://www.ontologydesignpatterns.org/ont/dul/DUL#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:list="https://cdm.ovh/rsm/list2/list2#"
     xmlns:loca="https://cdm.ovh/rsm/localisation/loca#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:rgeo="https://cdm.ovh/rsm/geosparql_adapter/rgeo#"
     xmlns:rlrs="https://cdm.ovh/rsm/linearReferencing/rlrs#"
     xmlns:side="https://cdm.ovh/rsm/schemes/side#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:time="http://www.w3.org/2006/time#"
     xmlns:topo="https://cdm.ovh/rsm/topology/topology#"
     xmlns:vann="https://vocab.org/vann/"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:geosparql="http://www.opengis.net/ont/geosparql#">
    <owl:Ontology rdf:about="https://cdm.ovh/rsm/localisation/loca">
        <owl:versionIRI rdf:resource="https://cdm.ovh/rsm/localisation/2.0/loca"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/linearReferencing/rlrs"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/list2/list2"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/topology/topo"/>
        <dc:creator>Airy Magnien</dc:creator>
        <dc:date xml:lang="en">16 April 2026</dc:date>
        <dc:description xml:lang="en">This ontology allows to place things on the topology. Things may have locations of type spot-, linear-, or area location.

For ordering things, this ontology uses the List ontology published by Pieter Pauwels and Walter Terkaj. The List ontology also underpins the ifcOWL ontology by the same authors.

For spot locations (and, by extension, for linear locations) on linear elements, it is possible to indicate offsets, quantitatively or qualitvely, in three directions: tangential (projected on the horizontal plane), transversal (orthogonal to tangential, same plane), and vertical.</dc:description>
        <dc:title xml:lang="en">Localisation</dc:title>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by-sa/4.0/"/>
        <rdfs:label xml:lang="en">Localisation</rdfs:label>
        <owl:versionInfo xml:lang="en">2.0 ontology based on expanded rlrs (Linear Referencing) ontology version 0.2. Offset expression corrected, generalized, and simplified.</owl:versionInfo>
        <vann:preferredNamespacePrefix>loca</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceURI>https://cdm.ovh/rsm/localisation/loca</vann:preferredNamespaceURI>
    </owl:Ontology>
    


