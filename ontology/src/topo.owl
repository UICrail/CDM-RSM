    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/abstract -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/abstract"/>
    


    <!-- http://purl.org/dc/elements/1.1/contributor -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/contributor"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/elements/1.1/type -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/type"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- https://vocab.org/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="https://vocab.org/vann/preferredNamespacePrefix"/>
    


    <!-- https://vocab.org/vann/preferredNamespaceURI -->

    <owl:AnnotationProperty rdf:about="https://vocab.org/vann/preferredNamespaceURI"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/topology/topo#connectedWith -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#connectedWith">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/topology/topo#connectedWithTransitive"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:label xml:lang="en">connected with</rdfs:label>
        <skos:definition xml:lang="en">Relation between a port on a net element and the adjacent port on another net element. This is a symmetric relation. Geographic locations of related ports may not coincide, either because of constructive tolerances (abutted tracks...), or uncertainties, or rounding errors, or by construction (e.g. case of tracks joined via a turntable).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#connectedWithTransitive -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#connectedWithTransitive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:label xml:lang="en">connected with transitive</rdfs:label>
        <skos:definition xml:lang="en">transitive closure of connectedWith.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#leadsTo -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#leadsTo">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/topology/topo#leadsToTransitive"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/rsm/topology/topo#port"/>
            <rdf:Description rdf:about="https://cdm.ovh/rsm/topology/topo#navigableTo"/>
            <rdf:Description rdf:about="https://cdm.ovh/rsm/topology/topo#onElement"/>
        </owl:propertyChainAxiom>
        <rdfs:label xml:lang="en">leads to</rdfs:label>
        <skos:definition xml:lang="en">relation between two adjacent net elements (i.e. having connected ports), where rolling stock can start moving from the first and arrive on the second without reversing travel direction. This property is not symmetric (think of sprung switches). A shortcut property for reasoning directly on net elements.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#leadsToTransitive -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#leadsToTransitive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/topology/topo#NetElement"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/topology/topo#NetElement"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/rsm/topology/topo#port"/>
            <rdf:Description rdf:about="https://cdm.ovh/rsm/topology/topo#navigableToTransitive"/>
            <rdf:Description rdf:about="https://cdm.ovh/rsm/topology/topo#onElement"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">technical note: this may look like, but is *not* the transitive closure of leadsTo. The transitive closure of leadsTo would include train movements with reversal of travel direction, which is not desirable.</rdfs:comment>
        <rdfs:label xml:lang="en">leads to transitive</rdfs:label>
        <skos:definition xml:lang="en">relation between net elements (adjacent or not), where rolling stock may leave the first (subject) and reach the second (object) without reversing travel direction.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#navigableFrom -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#navigableFrom">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/topology/topo#navigableFromTransitive"/>
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/topology/topo#navigableTo"/>
        <owl:propertyDisjointWith rdf:resource="https://cdm.ovh/rsm/topology/topo#nonNavigableFrom"/>
        <rdfs:label xml:lang="en">navigable from</rdfs:label>
        <skos:definition xml:lang="en">inverse of navigable to</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#navigableFromTransitive -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#navigableFromTransitive">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/topology/topo#navigableToTransitive"/>
        <rdfs:label xml:lang="en">navigable from transitive</rdfs:label>
        <skos:definition xml:lang="en">inverse of navigable to transitive</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#navigableTo -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#navigableTo">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/topology/topo#navigableToTransitive"/>
        <owl:propertyDisjointWith rdf:resource="https://cdm.ovh/rsm/topology/topo#nonNavigableTo"/>
        <rdfs:comment xml:lang="en">Expresses the possibility, for a train movement, to leave a net element via an exit port and to navigate to another net element until another exit port. Navigation excludes reversal of travel direction, even if the reversal is allowed by operational rules (e.g. shunting mode, ...).</rdfs:comment>
        <rdfs:label xml:lang="en">navigable to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#navigableToTransitive -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#navigableToTransitive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:label xml:lang="en">navigable to transitive</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#nonNavigableFrom -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#nonNavigableFrom">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/topology/topo#nonNavigableTo"/>
        <rdfs:label xml:lang="en">non navigable from</rdfs:label>
        <skos:definition xml:lang="en">inverse of non navigable to</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#nonNavigableTo -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#nonNavigableTo">
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:label xml:lang="en">non navigable to</rdfs:label>
        <skos:definition xml:lang="en">Expresses that there is no navigability link between the related ports. Given the OWA (open world assumption), a navigability not expressed does not mean &quot;non navigability&quot;. Consequently, non-navigability should be explicitly stated, as it is fundamental knowledge about the network layout.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#onElement -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#onElement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:label xml:lang="en">on element</rdfs:label>
        <skos:definition xml:lang="en">inverse of port, port0, port1</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#oppositePort -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#oppositePort">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://cdm.ovh/rsm/topology/topo#port0onElement"/>
            <rdf:Description rdf:about="https://cdm.ovh/rsm/topology/topo#port1"/>
        </owl:propertyChainAxiom>
        <rdfs:comment xml:lang="en">Opposite port on a linear element; a symmetric property. Not meaningful if element is non-linear.</rdfs:comment>
        <rdfs:label xml:lang="en">opposite port</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#port -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#port">
        <rdfs:subPropertyOf>
            <rdf:Description>
                <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/topology/topo#onElement"/>
            </rdf:Description>
        </rdfs:subPropertyOf>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/topology/topo#NetElement"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:label xml:lang="en">port</rdfs:label>
        <skos:definition xml:lang="en">Associated ports with net elements. This is an inverse functional property, meaning that a port can belong to at most one net element (if a port is found to belong to two net elements, the inference is that those two elements are the same).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#port0 -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#port0">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/topology/topo#port"/>
        <rdfs:subPropertyOf>
            <rdf:Description>
                <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/topology/topo#port0onElement"/>
            </rdf:Description>
        </rdfs:subPropertyOf>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <owl:propertyDisjointWith rdf:resource="https://cdm.ovh/rsm/topology/topo#port1"/>
        <rdfs:label xml:lang="en">port 0</rdfs:label>
        <skos:definition xml:lang="en">First port of some net element that has, by definition, two ports. Allows to orient linear elements in space, even though linear elements may be completely symmetrical from a functional point of view. Orientation is conventional. Can also be used on non-linear elements, with undefined semantics.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#port0onElement -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#port0onElement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:label xml:lang="en">port0on element</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#port1 -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#port1">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/topology/topo#port"/>
        <rdfs:subPropertyOf>
            <rdf:Description>
                <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/topology/topo#port1onElement"/>
            </rdf:Description>
        </rdfs:subPropertyOf>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/topology/topo#LinearElement"/>
        <rdfs:label>port 1</rdfs:label>
        <skos:definition xml:lang="en">the other port on a linear element.</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/topology/topo#port1onElement -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/topology/topo#port1onElement">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:label xml:lang="en">port1on element</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#Feature -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#Feature"/>
    


    <!-- https://cdm.ovh/rsm/topology/topo#BoundaryElement -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#BoundaryElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#LinearElement"/>
        <rdfs:label xml:lang="en">Boundary element</rdfs:label>
        <skos:definition xml:lang="en">Linear element with length = 0. It still has two distinct port, allowing to express connectivity and navigability (without losing directional information or the possibility to restrict navigation to a single direction). To be used at the borders of networks managed by different entities.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#LinearElement -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#LinearElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#NetElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/topology/topo#NonlinearElement"/>
        <rdfs:comment xml:lang="en">Any topology element that has exactly two extremities or &quot; ports&quot;.</rdfs:comment>
        <rdfs:label xml:lang="en">Linear element</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#ListedPort -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#ListedPort">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/list#OWLList"/>
        <rdfs:label xml:lang="en">Listed port</rdfs:label>
        <skos:definition xml:lang="en">A port in an ordered list (with successors; no contents needed). Can be used to sort the ports of a non-linear net element (e.g. clockwise from northmost). See also OWLList ontology.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#NetElement -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#NetElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#Feature"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:label xml:lang="en">Net element</rdfs:label>
        <skos:definition xml:lang="en">Superclass for net elements (network elements)</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#NonlinearElement -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#NonlinearElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#NetElement"/>
        <rdfs:label xml:lang="en">Nonlinear element</rdfs:label>
        <skos:definition xml:lang="en">Net element with any number of ports except two. Used for expressing connexities and navigabilities from or to a complex network area (e.g. a yard or a station).</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#Port -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#Port">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#Feature"/>
        <rdfs:label>Port</rdfs:label>
        <skos:definition xml:lang="en">Any place, at the boundary of a net element, that can be an entry and/or exit point for rolling stock. In the case of linear elements, there are exactly two ports. In the case of a loop, the two ports of the loop ports coincide geographically (but for some tolerances) but remain distinct individuals, allowing to orient the loop if need be.</skos:definition>
    </owl:Class>
    


    <!-- https://w3id.org/list#OWLList -->

    <owl:Class rdf:about="https://w3id.org/list#OWLList"/>
</rdf:RDF>



