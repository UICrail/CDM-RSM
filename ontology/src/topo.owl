<?xml version="1.0"?>
<rdf:RDF xmlns="https://cdm.ovh/rsm/topology/topo#"
     xml:base="https://cdm.ovh/rsm/topology/topo"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:dul="http://www.ontologydesignpatterns.org/ont/dul/DUL#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:list="https://w3id.org/list#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:topo="https://cdm.ovh/rsm/topology/topo#"
     xmlns:vann="https://vocab.org/vann/"
     xmlns:geo_ad="https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:geosparql="http://www.opengis.net/ont/geosparql#">
    <owl:Ontology rdf:about="https://cdm.ovh/rsm/topology/topo">
        <owl:versionIRI rdf:resource="https://cdm.ovh/rsm/topology/1.0rc7/topo"/>
        <owl:imports rdf:resource="https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad"/>
        <dc:abstract xml:lang="en">RSM topology provides fundamental railway network description, focused on connections and navigabilities between net elements. Net elements can be linear (embodied by lines or tracks) or non linear (embodied by stations, yards, or wider network areas). Geometry aspects are delegated to GeoSPARQL and are not essential to topology. Functional aspects (such as &quot;current switch setting&quot;) also are not part of the topology.</dc:abstract>
        <dc:contributor xml:lang="en">Pierre Tane, UIC</dc:contributor>
        <dc:creator xml:lang="en">Airy Magnien, UIC</dc:creator>
        <dc:date xml:lang="en">11 March 2026</dc:date>
        <dc:description xml:lang="en">Full RSM topology. Connexities and Navigabilities as object properties only. Temporal aspects to be covered by annotations and/or named graphs and/or dul:Situations, or similar.

Syntactic sugar: some properties that are most likely to be used are chained properties, equivalent to derived associations in UML.

Temporality to be expressed using an upper ontology, such as DOLCE+DnS Ultralite that is used by other RSM ontologies.</dc:description>
        <dc:title xml:lang="en">RSM topology</dc:title>
        <dc:type xml:lang="en">RDF/OWL ontology (using OWL2 RL profile)</dc:type>
        <dcterms:license xml:lang="en">CC BY-SA 4.0</dcterms:license>
        <owl:versionInfo xml:lang="en">removed reified Connectivity and Navigability relations. Added property oppositePort as a property chain, and related properties.</owl:versionInfo>
        <vann:preferredNamespacePrefix>topo</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceURI xml:lang="en">http://cdm.ovh/rsm/topology/topo#</vann:preferredNamespaceURI>
    </owl:Ontology>
    


    <!-- 
