<?xml version="1.0"?>
<rdf:RDF xmlns="https://cdm.ovh/rsm/geosparql_adapter/rgeo#"
     xml:base="https://cdm.ovh/rsm/geosparql_adapter/rgeo"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:geo="http://www.opengis.net/ont/geosparql#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:loca="https://cdm.ovh/rsm/localisation/loca#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:rgeo="https://cdm.ovh/rsm/geosparql_adapter/rgeo#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:topo="https://cdm.ovh/rsm/topology/topo#"
     xmlns:vann="https://vocab.org/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo">
        <owl:versionIRI rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/0.7/rgeo"/>
        <dc:abstract xml:lang="en">Adapter vocabulary for connecting various parts of RSM with GeoSPARQL 1.1.</dc:abstract>
        <dc:creator>Airy Magnien, UIC</dc:creator>
        <dc:date xml:lang="en">8 April 2026</dc:date>
        <dc:title xml:lang="en">GeoSPARQL adapter for semantic RSM</dc:title>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by-sa/4.0/"/>
        <owl:versionInfo xml:lang="en">0.7 : Edited annotation properties that caused profile violations. Replaced xsd:double by xsd:decimal. Renamed LinearThings to LinearThing.</owl:versionInfo>
        <vann:preferredNamespacePrefix>rgeo</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceURI>https://cdm.ovh/rsm/geosparql_adapter/rgeo</vann:preferredNamespaceURI>
    </owl:Ontology>
    


    <!-- 
