    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/abstract -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/abstract"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/date -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/date"/>
    


    <!-- http://purl.org/dc/elements/1.1/source -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/source"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/license -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel"/>
    


    <!-- https://vocab.org/vann/preferredNamespacePrefix -->

    <owl:AnnotationProperty rdf:about="https://vocab.org/vann/preferredNamespacePrefix"/>
    


    <!-- https://vocab.org/vann/preferredNamespaceURI -->

    <owl:AnnotationProperty rdf:about="https://vocab.org/vann/preferredNamespaceURI"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#decimal -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#decimal"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.opengis.net/ont/geosparql#hasDefaultGeometry -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasDefaultGeometry">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
    </owl:ObjectProperty>
    


    <!-- http://www.opengis.net/ont/geosparql#hasGeometry -->

    <owl:ObjectProperty rdf:about="http://www.opengis.net/ont/geosparql#hasGeometry">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:range rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:label xml:lang="en">hasGeometry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#geometryOf -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#geometryOf">
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasGeometry"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:comment xml:lang="en">GeoSPARQL does not define this inverse property.</rdfs:comment>
        <rdfs:label xml:lang="en">geometry of</rdfs:label>
        <skos:definition xml:lang="en">inverse of hasGeometry</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasGeometry -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasGeometry">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasGeometry"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Geometry"/>
        <rdfs:label xml:lang="en">has geometry</rdfs:label>
        <skos:definition xml:lang="en">A spatial representation for a given Feature. As in GeoSPARQL, a feature can be associated with more than one geometry (valid at different times, or provided by different surveys...).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalGeometry -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalGeometry">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasDefaultGeometry"/>
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasGeometry"/>
        <owl:inverseOf rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#nominalGeometryOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:label xml:lang="en">has nominal geometry</rdfs:label>
        <skos:definition xml:lang="en">The default Geometry to be used in spatial calculations. It is usually the most detailed Geometry. Takes into account SOSA/SSN viewpoint, i.e. there can be more than one default geometry (e.g. valid at different times).</skos:definition>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#nominalGeometryOf -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#nominalGeometryOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:label xml:lang="en">nominal geometry of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.opengis.net/ont/geosparql#hasMetricLength -->

    <owl:DatatypeProperty rdf:about="http://www.opengis.net/ont/geosparql#hasMetricLength">
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasMetricLength -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasMetricLength">
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasMetricLength"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#LinearThing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has metric length</rdfs:label>
        <skos:definition xml:lang="en">Length (in meter) of a Linear Element.</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalMetricLength -->

    <owl:DatatypeProperty rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalMetricLength">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasMetricLength"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/topology/topo#LinearElement"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="en">has nominal metric length</rdfs:label>
        <skos:definition>This length is assumed to be derived from the chosen Nominal Geometry.

The Nominal Metric Length is supposed to be used for conversions between linear referencing methods &quot;absolute&quot; (distance along, e.g. used in CCS/TMS data model) and &quot;interpolation&quot; (intrinsic coordinates, with values 0 to 1, used in RSM and others).</skos:definition>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.opengis.net/ont/geosparql#Feature -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Feature"/>
    


    <!-- http://www.opengis.net/ont/geosparql#Geometry -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#Geometry"/>
    


    <!-- http://www.opengis.net/ont/geosparql#SpatialObject -->

    <owl:Class rdf:about="http://www.opengis.net/ont/geosparql#SpatialObject"/>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:label xml:lang="en">Feature</rdfs:label>
        <skos:definition xml:lang="en">A discrete spatial phenomenon in the CDM universe of discourse.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#Geometry -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Geometry">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <dc:source xml:lang="en">OGC 18-010r11</dc:source>
        <rdfs:comment xml:lang="en">The reference system can be geographic, geodetic, cartesian (e.g. engineering coordinate system), and its definition may be part of the WKT or GML string. See OGC documentation.</rdfs:comment>
        <rdfs:label xml:lang="en">Geometry</rdfs:label>
        <skos:definition xml:lang="en">A coherent set of direct positions in space. The positions are held within a Spatial Reference System (SRS).</skos:definition>
        <skos:prefLabel xml:lang="en">Geometry</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/geosparql_adapter/rgeo#LinearThing -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/geosparql_adapter/rgeo#LinearThing">
        <rdfs:comment xml:lang="en">&quot; Abstract&quot;  class, introduced solely for the purpose of defining the domain of hasMetricLength in an OWL2-RL compatible way.</rdfs:comment>
        <rdfs:label xml:lang="en">Linear thing</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#BaseLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#BaseLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/localisation/loca#LinearLocation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/loca#LinearLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#LinearThing"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#LinearElement -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#LinearElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/geosparql_adapter/rgeo#LinearThing"/>
    </owl:Class>
</rdf:RDF>



