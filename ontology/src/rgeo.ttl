@prefix : <https://cdm.ovh/rsm/geosparql_adapter/rgeo#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix loca: <https://cdm.ovh/rsm/localisation/loca#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rgeo: <https://cdm.ovh/rsm/geosparql_adapter/rgeo#> .
@prefix skos: <https://www.w3.org/2004/02/skos/core#> .
@prefix topo: <https://cdm.ovh/rsm/topology/topo#> .
@base <https://cdm.ovh/rsm/geosparql_adapter/rgeo> .

<https://cdm.ovh/rsm/geosparql_adapter/rgeo> rdf:type owl:Ontology ;
                                              owl:versionIRI <https://cdm.ovh/rsm/geosparql_adapter/0.7/rgeo> ;
                                              <http://purl.org/dc/elements/1.1/abstract> "Adapter vocabulary for connecting various parts of RSM with GeoSPARQL 1.1."@en ;
                                              <http://purl.org/dc/elements/1.1/creator> "Airy Magnien, UIC" ;
                                              <http://purl.org/dc/elements/1.1/date> "8 April 2026"@en ;
                                              <http://purl.org/dc/elements/1.1/title> "GeoSPARQL adapter for semantic RSM"@en ;
                                              <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by-sa/4.0/> ;
                                              owl:versionInfo "0.7 : Edited annotation properties that caused profile violations. Replaced xsd:double by xsd:decimal. Renamed LinearThings to LinearThing."@en ;
                                              <https://vocab.org/vann/preferredNamespacePrefix> "rgeo" ;
                                              <https://vocab.org/vann/preferredNamespaceURI> "https://cdm.ovh/rsm/geosparql_adapter/rgeo" .

