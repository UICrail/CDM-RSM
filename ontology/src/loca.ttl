@prefix : <https://cdm.ovh/rsm/localisation/loca#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dul: <http://www.ontologydesignpatterns.org/ont/dul/DUL#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix list: <https://cdm.ovh/rsm/list2/list2#> .
@prefix loca: <https://cdm.ovh/rsm/localisation/loca#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rgeo: <https://cdm.ovh/rsm/geosparql_adapter/rgeo#> .
@prefix rlrs: <https://cdm.ovh/rsm/linearReferencing/rlrs#> .
@prefix side: <https://cdm.ovh/rsm/schemes/side#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix topo: <https://cdm.ovh/rsm/topology/topology#> .
@prefix vann: <https://vocab.org/vann/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix geosparql: <http://www.opengis.net/ont/geosparql#> .
@base <https://cdm.ovh/rsm/localisation/loca> .

<https://cdm.ovh/rsm/localisation/loca> rdf:type owl:Ontology ;
                                         owl:versionIRI <https://cdm.ovh/rsm/localisation/2.0/loca> ;
                                         owl:imports <https://cdm.ovh/rsm/linearReferencing/rlrs> ,
                                                     <https://cdm.ovh/rsm/list2/list2> ,
                                                     <https://cdm.ovh/rsm/topology/topo> ;
                                         dc:creator "Airy Magnien" ;
                                         dc:date "16 April 2026"@en ;
                                         dc:description """This ontology allows to place things on the topology. Things may have locations of type spot-, linear-, or area location.

For ordering things, this ontology uses the List ontology published by Pieter Pauwels and Walter Terkaj. The List ontology also underpins the ifcOWL ontology by the same authors.

For spot locations (and, by extension, for linear locations) on linear elements, it is possible to indicate offsets, quantitatively or qualitvely, in three directions: tangential (projected on the horizontal plane), transversal (orthogonal to tangential, same plane), and vertical."""@en ;
                                         dc:title "Localisation"@en ;
                                         dcterms:license <https://creativecommons.org/licenses/by-sa/4.0/> ;
                                         rdfs:label "Localisation"@en ;
                                         owl:versionInfo "2.0 ontology based on expanded rlrs (Linear Referencing) ontology version 0.2. Offset expression corrected, generalized, and simplified."@en ;
                                         vann:preferredNamespacePrefix "loca" ;
                                         vann:preferredNamespaceURI "https://cdm.ovh/rsm/localisation/loca" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/date
dc:date rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  https://vocab.org/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  https://vocab.org/vann/preferredNamespaceURI
vann:preferredNamespaceURI rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://cdm.ovh/rsm/linearReferencing/rlrs#positionedBy
rlrs:positionedBy rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf [ owl:inverseOf rlrs:positionsObject
                                     ] ;
                  rdfs:domain dul:Object ;
                  rdfs:range rlrs:LinearPosition ;
                  rdfs:label "positioned by"@en .


###  https://cdm.ovh/rsm/linearReferencing/rlrs#positionsObject
rlrs:positionsObject rdf:type owl:ObjectProperty .


###  https://cdm.ovh/rsm/localisation/loca#atInterval
loca:atInterval rdf:type owl:ObjectProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain loca:TimedLocation ;
                rdfs:range time:Interval ;
                rdfs:label "at interval"@en .


###  https://cdm.ovh/rsm/localisation/loca#atLocation
loca:atLocation rdf:type owl:ObjectProperty ;
                rdfs:domain loca:TimedLocation ;
                rdfs:range loca:BaseLocation ;
                rdfs:label "at location"@en .


###  https://cdm.ovh/rsm/localisation/loca#forEntity
loca:forEntity rdf:type owl:ObjectProperty ;
               owl:inverseOf loca:hasTimedLocation ;
               rdfs:domain loca:TimedLocation ;
               rdfs:range dul:Entity ;
               rdfs:label "for entity"@en .


###  https://cdm.ovh/rsm/localisation/loca#hasTimedLocation
loca:hasTimedLocation rdf:type owl:ObjectProperty ;
                      rdfs:label "has timed location"@en .


###  https://cdm.ovh/rsm/localisation/loca#location
loca:location rdf:type owl:ObjectProperty ,
                       owl:InverseFunctionalProperty ;
              rdfs:range loca:BaseLocation ;
              rdfs:comment "Generic property assigning some location to a Thing."@en ;
              rdfs:label "location"@en .


#################################################################
#    Classes
#################################################################

###  http://www.ontologydesignpatterns.org/ont/dul/DUL#Entity
dul:Entity rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL#Object
dul:Object rdf:type owl:Class .


###  http://www.ontologydesignpatterns.org/ont/dul/DUL#Situation
dul:Situation rdf:type owl:Class .


###  http://www.w3.org/2006/time#Interval
time:Interval rdf:type owl:Class .


###  https://cdm.ovh/rsm/geosparql_adapter/rgeo#Feature
rgeo:Feature rdf:type owl:Class .


###  https://cdm.ovh/rsm/linearReferencing/rlrs#LinearPosition
rlrs:LinearPosition rdf:type owl:Class ;
                    rdfs:subClassOf list:OWLList .


###  https://cdm.ovh/rsm/list2/list2#OWLList
list:OWLList rdf:type owl:Class .


###  https://cdm.ovh/rsm/localisation/loca#AreaLocation
loca:AreaLocation rdf:type owl:Class ;
                  rdfs:subClassOf loca:BaseLocation ;
                  rdfs:label "Area location"@en ;
                  skos:definition "The class of all locations that are neither spot, nor linear. Concrete examples: the location of a GSM coverage area (i.e. the parts of topology elements that are in this area); a set of discontinuous or branching linear locations. An area location refers to a set of topology elements, or element parts: no order, no repetition."@en .


###  https://cdm.ovh/rsm/localisation/loca#BaseLocation
loca:BaseLocation rdf:type owl:Class ;
                  rdfs:subClassOf dul:Object ,
                                  rgeo:Feature ;
                  rdfs:label "Base location"@en ;
                  skos:definition "Class of all locations relative to a topology. Disjoint union of its three subclasses (spot-, linear-, area location)."@en .


###  https://cdm.ovh/rsm/localisation/loca#ConnectedAreaLocation
loca:ConnectedAreaLocation rdf:type owl:Class ;
                           rdfs:subClassOf loca:AreaLocation ;
                           rdfs:comment "Area location, all elements of which are connected with all other elements, directly or indirectly (ports connected transitively)."@en ;
                           rdfs:label "Connected area location"@en .


###  https://cdm.ovh/rsm/localisation/loca#LinearLocation
loca:LinearLocation rdf:type owl:Class ;
                    rdfs:subClassOf loca:BaseLocation ;
                    rdfs:label "Linear location"@en ;
                    skos:definition "Location extending over consecutive linear elements or parts thereof. The involved linear elements are in a sequence (ordered list, with repetitions allowed). Each linear element in the sequence is oriented from start to end. Start and end may coincide with extremities or some point in between."@en .


###  https://cdm.ovh/rsm/localisation/loca#SpotLocation
loca:SpotLocation rdf:type owl:Class ;
                  rdfs:subClassOf loca:BaseLocation ;
                  rdfs:label "Spot location"@en ;
                  skos:definition "Class of all spot locations, i.e. locations that can be represented as a point on a map or schema. The spot location can relate to one or more net elements (concrete example: the location of a signal that addresses two converging tracks)."@en .


###  https://cdm.ovh/rsm/localisation/loca#TimedLocation
loca:TimedLocation rdf:type owl:Class ;
                   rdfs:subClassOf dul:Situation ;
                   rdfs:comment "a situation bringing together an Entity with a location and a time interval. It is a reified ternary relation, not a \"Location\" as the label would suggest."@en ;
                   rdfs:label "Timed location"@en .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( loca:AreaLocation
                loca:LinearLocation
                loca:SpotLocation
              )
] .


