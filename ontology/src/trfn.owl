    <!-- https://cdm.ovh/rsm/track/trfn#TurnoutOrientation -->

    <owl:Class rdf:about="https://cdm.ovh/rsm/track/trfn#TurnoutOrientation">
        <rdfs:comment xml:lang="en">Defines the geometric layout of a turnout: value Left  means that the diverted track curves to the left, while the through track is straight ahead. A symmetric (rather: Y-shaped) turnout curves to both sides. In the rare cases where turnouts are on a curve, the diverted track is the one with a radius of curvature that is different from the incoming track.</rdfs:comment>
        <rdfs:label xml:lang="en">Turnout orientation</rdfs:label>
    </owl:Class>
    


