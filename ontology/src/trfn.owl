        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/track/trfn#LocatedTrackEntity"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/localisation/loca#BaseLocation"/>
        <rdfs:comment xml:lang="en">Location can be representation-dependent and time-dependent (maintenance !), so this property is not functional.</rdfs:comment>
        <rdfs:label xml:lang="en">track entity location</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/track/trfn#turnoutOrientation -->

