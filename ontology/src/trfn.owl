        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/track/trfn#Turnout"/>
        <rdfs:comment xml:lang="en">indicates which navigabilities are available when the turnout is locked in its rightmost position</rdfs:comment>
        <rdfs:label xml:lang="en">right lock</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/track/trfn#throughLock -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/track/trfn#throughLock">
