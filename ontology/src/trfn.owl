    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/track/trfn#trackEntityLocation -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/track/trfn#trackEntityLocation">
