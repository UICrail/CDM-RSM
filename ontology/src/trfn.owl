        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/track/trfn#JunctionEntity"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:label xml:lang="en">handles ports</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/track/trfn#leftLock -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/track/trfn#leftLock">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/track/trfn#handlesNavigability"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/track/trfn#Turnout"/>
        <owl:propertyDisjointWith rdf:resource="https://cdm.ovh/rsm/track/trfn#rightLock"/>
        <rdfs:comment xml:lang="en">Navigabilities involved by the turnout being locked on the left position are a subset of all navigabilities handled by the turnout. It is disjoint from the navigabilities involved by a lock on the right position.</rdfs:comment>
        <rdfs:comment xml:lang="en">indicates which navigabilities are available when the turnout is locked in its leftmost position</rdfs:comment>
        <rdfs:label xml:lang="en">left lock</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/track/trfn#rightLock -->

