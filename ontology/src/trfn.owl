        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/track/trfn#Turnout"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/track/trfn#TurnoutOrientation"/>
        <rdfs:label xml:lang="en">turnout orientation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://cdm.ovh/rsm/track/trfn#turnoutOrigin -->

    <owl:ObjectProperty rdf:about="https://cdm.ovh/rsm/track/trfn#turnoutOrigin">
        <rdfs:subPropertyOf rdf:resource="https://cdm.ovh/rsm/localisation/loca#location"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://cdm.ovh/rsm/track/trfn#Turnout"/>
        <rdfs:range rdf:resource="https://cdm.ovh/rsm/localisation/loca#SpotLocation"/>
        <rdfs:comment xml:lang="en">The location where the &quot;throught&quot; and &quot;diverted&quot; tracks diverge. Conventionally set at the tangential or secant point of track centerlines, which may differ from the location of blade tips.
Note: blade tips are not in the scope of the (functional) turnout object.</rdfs:comment>
        <rdfs:label xml:lang="en">turnout origin</rdfs:label>
    </owl:ObjectProperty>
    


