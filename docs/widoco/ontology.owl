    <!-- https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Feature -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Feature">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Feature"/>
        <rdfs:label xml:lang="en">Feature</rdfs:label>
        <skos:definition xml:lang="en">A discrete spatial phenomenon in the CDM universe of discourse.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Geometry -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Geometry">
        <rdfs:subClassOf rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <dc:source xml:lang="en">OGC 18-010r11</dc:source>
        <rdfs:comment xml:lang="en">The reference system can be geographic, geodetic, cartesian (e.g. engineering coordinate system), and its definition may be part of the WKT or GML string. See OGC documentation.</rdfs:comment>
        <rdfs:label xml:lang="en">Geometry</rdfs:label>
        <skos:definition xml:lang="en">A coherent set of direct positions in space. The positions are held within a Spatial Reference System (SRS).</skos:definition>
        <skos:prefLabel xml:lang="en">Geometry</skos:prefLabel>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#LinearThings -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#LinearThings">
        <rdfs:comment xml:lang="en">&quot; Abstract&quot;  class, introduced solely for the purpose of defining the domain of hasMetricLength in an OWL2-RL compatible way.</rdfs:comment>
        <rdfs:label xml:lang="en">Linear things</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#Feature -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#Feature"/>
    


    <!-- https://cdm.ovh/rsm/localisation/localisation#BaseLocation -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/localisation#BaseLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Feature"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/localisation/localisation#LinearLocation -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/localisation/localisation#LinearLocation">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#LinearThings"/>
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/localisation/localisation#BaseLocation"/>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#BoundaryElement -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#BoundaryElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#LinearElement"/>
        <rdfs:label xml:lang="en">Boundary element</rdfs:label>
        <skos:definition xml:lang="en">Linear element with length = 0. It still has two distinct port, allowing to express connectivity and navigability (without losing directional information or the possibility to restrict navigation to a single direction). To be used at the borders of networks managed by different entities.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#LinearElement -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#LinearElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#NetElement"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/topology/topo#NonlinearElement"/>
        <rdfs:comment xml:lang="en">Any topology element that has exactly two extremities or &quot; ports&quot;.</rdfs:comment>
        <rdfs:label xml:lang="en">Linear element</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#ListedPort -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#ListedPort">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/list#OWLList"/>
        <rdfs:label xml:lang="en">Listed port</rdfs:label>
        <skos:definition xml:lang="en">A port in an ordered list (with successors; no contents needed). Can be used to sort the ports of a non-linear net element (e.g. clockwise from northmost). See also OWLList ontology.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#Navigability -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#Navigability">
        <rdfs:comment xml:lang="en">Note: non-navigability and connexity reification are not proposed here, assuming that:
1. the authority lies with the properties (navigableTo, nonNavigableTo, connectedWith), and
2. navigabilities as individuals are useful for further modelling (switches...), while non-navigabilities and connexities as individuals do not appear to be equally useful.</rdfs:comment>
        <rdfs:comment xml:lang="en">Reified navigability relation. It is oriented (from port - to port); see navigableTo property for details.</rdfs:comment>
        <rdfs:label xml:lang="en">Navigability</rdfs:label>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#NetElement -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#NetElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#Feature"/>
        <owl:disjointWith rdf:resource="https://cdm.ovh/rsm/topology/topo#Port"/>
        <rdfs:label xml:lang="en">Net element</rdfs:label>
        <skos:definition xml:lang="en">Superclass for net elements (network elements)</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#NonlinearElement -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#NonlinearElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/topology/topo#NetElement"/>
        <rdfs:label xml:lang="en">Nonlinear element</rdfs:label>
        <skos:definition xml:lang="en">Net element with any number of ports except two. Used for expressing connexities and navigabilities from or to a complex network area (e.g. a yard or a station).</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topo#Port -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topo#Port">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/adapters/geosparql_adapter/geosparql_adapter#Feature"/>
        <rdfs:label>Port</rdfs:label>
        <skos:definition xml:lang="en">Any place, at the boundary of a net element, that can be an entry and/or exit point for rolling stock. In the case of linear elements, there are exactly two ports. In the case of a loop, the two ports of the loop ports coincide geographically (but for some tolerances) but remain distinct individuals, allowing to orient the loop if need be.</skos:definition>
    </owl:Class>
    


    <!-- https://cdm.ovh/rsm/topology/topology#LinearElement -->


    <owl:Class rdf:about="https://cdm.ovh/rsm/topology/topology#LinearElement">
        <rdfs:subClassOf rdf:resource="https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#LinearThings"/>
    </owl:Class>
    


    <!-- https://w3id.org/list#OWLList -->


    <owl:Class rdf:about="https://w3id.org/list#OWLList"/>
</rdf:RDF>



