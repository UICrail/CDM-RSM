              <subject>https://cdm.ovh/rsm/topology/topo#NonlinearElement</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>Net element with any number of ports except two. Used for expressing connexities and navigabilities outside a complex network area (e.g. a yard or a station).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/topology/topo#Port</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#Port</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Port</lexicalForm>
                <datatype/>
                <language/>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#Port</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>Any place, at the boundary of a net element, that can be an entry and/or exit point for rolling stock. In the case of linear elements, there are exactly two ports. These may coincide (loop case) or be distinct (general case).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/topology/topo#connectedWith</value>
          <symmetric/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#connectedWith</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>connected with</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#connectedWith</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>Relation between a port on a net element and the asjacent port on another net element. Geographic locations of related ports may not coincide, either because of uncertainties or rounding errors, or by construction (e.g. case of tracks joined via a turntable).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
