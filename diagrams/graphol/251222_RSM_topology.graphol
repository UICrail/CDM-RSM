        <iri>
          <value>https://cdm.ovh/rsm/topology/topo#nonNavigableTo</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#nonNavigableTo</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>non navigable to</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#nonNavigableTo</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>Expresses that there is no navigability link between the related ports. Given the OWA (open world assumption), a navigability not expressed does not mean "non navigability". Consequently, non-navigability should be explicitly stated, as it is important knowledge.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
