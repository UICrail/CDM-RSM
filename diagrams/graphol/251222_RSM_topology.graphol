              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>leads to transitive</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#leadsToTransitive</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>relation between net elements (adjacent or not), where rolling stock may leave the first and reach the second without reversing travel direction.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
