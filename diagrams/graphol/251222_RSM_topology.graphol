            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#Navigability</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>a (reified) relation between two ports of two distinct net elements.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
