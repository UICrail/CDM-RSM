              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>inverse of port, port0, port1</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/topology/topo#port</value>
          <inverseFunctional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#port</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>port</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#port</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>Associated ports with net elements. This is an inverse functional property, meaning that a port can belong to at most one net element (if a port is found to belong to two net elements, the inference is that those two elements are the same).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
