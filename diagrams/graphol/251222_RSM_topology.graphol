        <iri>
          <value>https://cdm.ovh/rsm/topology/topo#connectsPort</value>
          <inverseFunctional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#connectsPort</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>connects port</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/topology/topo#connectsPort</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>This object property points to (at least two) ports that share a connection relationship.

It is used for building the connectedWith properties. It can be a temporal object, although this is not (yet) the case in this version.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
