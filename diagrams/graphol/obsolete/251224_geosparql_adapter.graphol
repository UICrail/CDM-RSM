            <annotation>
              <subject>https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Geometry</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>A coherent set of direct positions in space. The positions are held within a Spatial Reference System (SRS).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Geometry</subject>
              <property>http://purl.org/dc/elements/1.1/source</property>
              <object>
                <lexicalForm>OGC 18-010r11</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Geometry</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>The reference system can be geographic, geodetic, cartesian (e.g. engineering coordinate system), and its definition may be part of the WKT or GML string. See OGC documentation.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Geometry</subject>
              <property>http://www.w3.org/2004/02/skos/core#prefLabel</property>
              <object>
                <lexicalForm>Geometry</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
