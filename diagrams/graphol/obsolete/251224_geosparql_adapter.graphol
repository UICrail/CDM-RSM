        <iri>
          <value>https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Geometry</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/adapters/geosparql_adapter/geo_ad#Geometry</subject>
