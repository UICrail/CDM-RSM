        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasGeometry</value>
          <inverseFunctional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasGeometry</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>has geometry</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasGeometry</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>A spatial representation for a given Feature. As in GeoSPARQL, a feature can be associated with more than one geometry (valid at different times, or provided by different surveys...).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasMetricLength</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasMetricLength</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>has metric length</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasMetricLength</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>Length (in meter) of a Linear Element.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalGeometry</value>
          <functional/>
          <inverseFunctional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalGeometry</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>has nominal geometry</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalGeometry</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>The default Geometry to be used in spatial calculations. It is usually the most detailed Geometry. Takes into account SOSA/SSN viewpoint, i.e. there can be more than one default geometry (e.g. valid at different times).</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalMetricLength</value>
          <functional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalMetricLength</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>has nominal metric length</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#hasNominalMetricLength</subject>
              <property>http://www.w3.org/2004/02/skos/core#definition</property>
              <object>
                <lexicalForm>This length is assumed to be derived from the chosen Nominal Geometry.

The Nominal Metric Length is supposed to be used for conversions between linear referencing methods "absolute" (distance along, e.g. used in CCS/TMS data model) and "interpolation" (intrinsic coordinates, with values 0 to 1, used in RSM and others).</lexicalForm>
                <datatype/>
                <language/>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/geosparql_adapter/rgeo#nominalGeometryOf</value>
