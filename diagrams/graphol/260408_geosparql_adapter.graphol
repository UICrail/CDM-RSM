        <iri>
          <value>https://cdm.ovh/rsm/geosparql_adapter/rgeo#Geometry</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/geosparql_adapter/rgeo#Geometry</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
