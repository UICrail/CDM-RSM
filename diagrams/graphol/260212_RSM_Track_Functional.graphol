          <functional/>
          <inverseFunctional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#turnoutOrigin</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>turnout origin</lexicalForm>
                <datatype/>
