        <iri>
          <value>https://cdm.ovh/rsm/track/trfn#TurnoutOrientation</value>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#TurnoutOrientation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>Turnout orientation</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#TurnoutOrientation</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Defines the geometric layout of a turnout: value Left  means that the diverted track curves to the left, while the through track is straight ahead. A symmetric (rather: Y-shaped) turnout curves to both sides. In the rare cases where turnouts are on a curve, the diverted track is the one with a radius of curvature that is different from the incoming track.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
