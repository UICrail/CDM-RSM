            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#turnoutOrigin</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>The location where the "throught" and "diverted" tracks diverge. Conventionally set at the tangential or secant point of track centerlines, which may differ from the location of blade tips.
Note: blade tips are not in the scope of the (functional) turnout object.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
