        <iri>
          <value>https://cdm.ovh/rsm/track/trfn#isSet</value>
          <functional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#isSet</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>is set</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#isSet</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Tells whether a Navigability relation is set, reflecting the setting of a crossing or a switch (turnout). Time-dependency is expressed e.g. using the Operations ontology or upper ontologies such as DUL (DOLCE+DnS Ultralite), as a generic way to add time dimension. Hardware state details (locking...), if needed, would be in the scope of hardware-related ontologies and signalling ontologies.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
        <iri>
          <value>https://cdm.ovh/rsm/track/trfn#leftLock</value>
          <inverseFunctional/>
          <annotations>
            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#leftLock</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#label</property>
              <object>
                <lexicalForm>left lock</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#leftLock</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>indicates which navigabilities are available when the turnout is locked in its leftmost position</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
            <annotation>
              <subject>https://cdm.ovh/rsm/track/trfn#leftLock</subject>
              <property>http://www.w3.org/2000/01/rdf-schema#comment</property>
              <object>
                <lexicalForm>Navigabilities involved by the turnout being locked on the left position are a subset of all navigabilities handled by the turnout. It is disjoint from the navigabilities involved by a lock on the right position.</lexicalForm>
                <datatype/>
                <language>en</language>
              </object>
            </annotation>
          </annotations>
        </iri>
